# 智谱 AI API
ZHIPU_API_KEY=your_zhipu_api_key_here

# LangSmith Tracing (可选)
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=langchain-learning
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Langfuse 追踪 (可选)
LANGFUSE_TRACING=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenRouter (可选)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 企业微信自建应用
# 在「应用管理」→ 应用 →「接收消息」→「API接收」中获取
WECHAT_WORK_CORP_ID=your_corp_id
WECHAT_WORK_AGENT_ID=your_agent_id
WECHAT_WORK_AGENT_SECRET=your_agent_secret
WECHAT_WORK_TOKEN=your_token
WECHAT_WORK_ENCODING_AES_KEY=your_encoding_aes_key

# Channel 超时配置（秒，默认 180）
CHANNEL_TIMEOUT=180
